{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ODDsama/oddinvest/contract/oddinvest-state.schema.json",
  "title": "oddinvest/state — контракт Go-сервіс -> інтеграція Home Assistant",
  "description": "Retained-повідомлення в топіку {prefix}/state. Еволюція: тільки додавання полів; зміна семантики = інкремент schema.",
  "type": "object",
  "required": [
    "schema",
    "generated_at",
    "invested_uah",
    "nominal_uah_eq",
    "usd_share_pct",
    "uninvested_uah",
    "month_invested_uah",
    "month_target_uah",
    "month_progress_pct",
    "month_incoming_uah",
    "ladder",
    "top_payments",
    "calendar"
  ],
  "properties": {
    "schema": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "invested_uah": {
      "type": "number",
      "minimum": 0
    },
    "nominal_uah_eq": {
      "type": "number",
      "minimum": 0
    },
    "usd_share_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "eur_share_pct": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "uninvested_uah": {
      "type": "number",
      "minimum": 0
    },
    "account_uah": {
      "type": "number"
    },
    "reinvest_min_uah": {
      "type": "number",
      "minimum": 0
    },
    "accounts": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "rates": {
      "type": "object",
      "description": "Курси НБУ на сьогодні, ₴ за одиницю валюти (адитивне поле). Доти курс у документ не потрапляв, і UI діставав його з forecast.rate0_usd — тобто лише коли задано ціль",
      "additionalProperties": { "type": "number" }
    },
    "reinvest_min": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "month_invested_uah": {
      "type": "number",
      "minimum": 0
    },
    "month_target_uah": {
      "type": "number",
      "minimum": 0
    },
    "month_progress_pct": {
      "type": "integer",
      "minimum": 0
    },
    "month_incoming_uah": {
      "type": "number",
      "minimum": 0
    },
    "insurance_days_left": {
      "type": [
        "integer",
        "null"
      ]
    },
    "next_payment": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "date",
        "isin",
        "type",
        "amount",
        "currency"
      ],
      "properties": {
        "date": {
          "type": "string",
          "format": "date"
        },
        "isin": {
          "type": "string",
          "pattern": "^UA[0-9A-Z]{10}$"
        },
        "type": {
          "enum": [
            "coupon",
            "redemption",
            "early"
          ]
        },
        "amount": {
          "type": "number"
        },
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3
        }
      }
    },
    "ladder": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "year",
          "uah",
          "usd"
        ],
        "properties": {
          "year": {
            "type": "integer",
            "minimum": 2000
          },
          "uah": {
            "type": "number",
            "minimum": 0
          },
          "usd": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "top_payments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date",
          "isin",
          "type",
          "amount",
          "currency"
        ],
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "isin": {
            "type": "string"
          },
          "type": {
            "enum": [
              "coupon",
              "redemption",
              "early"
            ]
          },
          "amount": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          }
        }
      }
    },
    "calendar": {
      "type": "array",
      "description": "Повний горизонт майбутніх виплат (v0.2+, адитивне поле)",
      "items": {
        "type": "object",
        "required": [
          "date",
          "isin",
          "type",
          "amount",
          "currency"
        ],
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "isin": {
            "type": "string"
          },
          "type": {
            "enum": [
              "coupon",
              "redemption",
              "early"
            ]
          },
          "amount": {
            "type": "number"
          },
          "currency": {
            "type": "string"
          }
        }
      }
    },
    "settings": {
      "type": [
        "object",
        "null"
      ],
      "description": "Сирі налаштування сервіса (v0.3+, адитивне поле)",
      "properties": {
        "monthly_target_uah": {
          "type": "number",
          "minimum": 0
        },
        "usd_target_share_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "eur_target_share_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "assumed_rate_pct": {
          "type": "number",
          "description": "Застаріле: проєкції беруть portfolio_yield_pct"
        },
        "goal_amount_uah": {
          "type": "number",
          "minimum": 0
        },
        "goal_date": {
          "type": "string",
          "format": "date"
        },
        "target_duration_years": {
          "type": "number",
          "minimum": 0,
          "description": "Бажана дюрація портфеля, років"
        },
        "channels": {
          "type": "string",
          "description": "Канали купівлі через кому (mono, inzhur…)"
        }
      }
    },
    "xirr": {
      "type": "object",
      "description": "Річний XIRR по валютах, % (v1.0+, адитивне поле)",
      "additionalProperties": {
        "type": "number"
      }
    },
    "portfolio_yield_pct": {
      "type": "number",
      "description": "Очікувана дохідність за придбаними паперами: купон за 12 міс ÷ номінал, зважено, грн-екв. (адитивне поле)"
    },
    "portfolio_yield_real": {
      "type": "object",
      "description": "Те саме після знецінення гривні, тобто в сьогоднішній купівельній спроможності. Валютні рукави проходять без поправки — долар тримає спроможність сам (адитивне поле)",
      "additionalProperties": { "type": "number" }
    },
    "funds_yield_real_pct": {
      "type": "number",
      "description": "Дохідність фондів після знецінення (адитивне поле)"
    },
    "blended_yield_real_pct": {
      "type": "number",
      "description": "Зведена дохідність після знецінення (адитивне поле)"
    },
    "portfolio_yield": {
      "type": "object",
      "description": "Очікувана дохідність по кожній валюті окремо, % НОМІНАЛЬНИХ (YTM за собівартістю лотів, зважена вкладеним; адитивне поле). Реальний двійник — portfolio_yield_real",
      "additionalProperties": { "type": "number" }
    },
    "projection": {
      "type": "array",
      "description": "Прогноз капіталу помісячною симуляцією реальних потоків (адитивне поле)",
      "items": {
        "type": "object",
        "properties": {
          "years": { "type": "integer" },
          "contributed": { "type": "number" },
          "with_reinvest": { "type": "number" }
        }
      }
    },
    "projection_rate_pct": { "type": "number", "description": "Ставка реінвесту в проєкції, %" },
    "goal_projection": { "type": "number", "description": "Прогноз капіталу на дату цілі, грн-екв." },
    "goal_required_monthly": { "type": "number", "description": "Потрібний внесок/міс для досягнення цілі, грн-екв." },
    "goal_months_left": { "type": "integer", "description": "Місяців до дати цілі" },
    "rebalance": {
      "type": "array",
      "description": "Підказка виходу на цільові валютні частки (адитивне поле)",
      "items": {
        "type": "object",
        "properties": {
          "currency": { "type": "string" },
          "target_pct": { "type": "number" },
          "current_pct": { "type": "number" },
          "deficit_uah": { "type": "number" },
          "deficit_native": { "type": "number" },
          "cash_native": { "type": "number" },
          "bond_cost_native": { "type": "number" },
          "bond_cost_uah": { "type": "number" },
          "can_buy": { "type": "integer" },
          "convert_uah": { "type": "number" },
          "min_portfolio_uah": { "type": "number" },
          "feasible": { "type": "boolean" }
        }
      }
    },
    "rate_risk": {
      "type": "object",
      "description": "Процентний ризик — два різні: ціновий (duration/pv/scenarios, ЛИШЕ ОВДП: тільки вони переоцінюються на вторинному ринку) і перевкладення (reinvest_*, ОВДП + вклади: коли гроші повернуться й підуть за новою ставкою). Адитивне поле.",
      "properties": {
        "duration_years": { "type": "number" },
        "modified_dur": { "type": "number" },
        "pv_uah": { "type": "number" },
        "by_currency": { "type": "object", "additionalProperties": { "type": "number" } },
        "reinvest_years": { "type": "number", "description": "середній строк повернення грошей, років (без дисконтування)" },
        "returning_uah": { "type": "number", "description": "скільки всього повернеться, грн-екв." },
        "reinvest_soon_uah": { "type": "number", "description": "з них протягом 12 місяців" },
        "scenarios": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "delta_pp": { "type": "number" },
              "change_pct": { "type": "number" },
              "change_uah": { "type": "number" }
            }
          }
        }
      }
    }
  }
}